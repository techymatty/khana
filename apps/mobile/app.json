{
  "expo": {
    "name": "UmmahEats",
    "slug": "ummaheats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "ummaheats",
    "splash": {
      "backgroundColor": "#0F9D58",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ummaheats.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F9D58"
      },
      "package": "com.ummaheats.app"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-location"]
  }
}
