{
  "name": "ummaheats",
  "version": "1.0.0",
  "private": true,
  "description": "UmmahEats — Halal Food Delivery Platform",
  "workspaces": [
    "apps/server",
    "apps/mobile"
  ],
  "scripts": {
    "server:dev": "cd apps/server && npm run start:dev",
    "server:build": "cd apps/server && npm run build",
    "mobile:start": "cd apps/mobile && npx expo start",
    "db:migrate": "cd apps/server && npx prisma migrate dev",
    "db:seed": "cd apps/server && npx prisma db seed",
    "db:studio": "cd apps/server && npx prisma studio"
  }
}
